# ============================================================
# AI 互联网嘴替系统 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的真实 API 凭据。
#   cp .env.example .env
# ============================================================

# OpenAI 兼容 API 的 Base URL
# 支持任何兼容 OpenAI Chat Completions 格式的服务：
#   - OpenAI 官方:    https://api.openai.com/v1
#   - DeepSeek:       https://api.deepseek.com/v1
#   - OpenRouter:     https://openrouter.ai/api/v1
#   - 本地 Ollama:     http://localhost:11434/v1
#   - 本地 LM Studio:  http://localhost:1234/v1
#   - 其他代理/中转:   按实际填写
AI_BASE_URL=https://api.openai.com/v1

# API Key
AI_API_KEY=sk-your-api-key-here

# 模型名称（需与所选 API 提供商支持的模型一致）
# 推荐：
#   - OpenAI:        gpt-4o / gpt-4o-mini
#   - DeepSeek:      deepseek-chat / deepseek-v4-pro / deepseek-reasoner
#   - OpenRouter:    anthropic/claude-sonnet-4 / openai/gpt-4o
#   - 本地模型:      按 Ollama/LM Studio 中的模型名填写
AI_MODEL=deepseek-v4-pro
