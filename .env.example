# ============================================================
# AI 互联网嘴替系统 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入真实凭据。
# ============================================================

# ---- DeepSeek（默认模型，纯文本场景） ----
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-you...
### ---- Kimi / 月之暗面（图片识别场景） ----
# 上传图片时自动切换到此模型
KIMI_API_KEY=sk-you...AI_MODEL=deepseek-chat
